<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("partials/head") %>
    <style>
      .landing-hero {
        text-align: center;
        margin-bottom: 48px;
      }

      .landing-avatar {
        width: 120px;
        height: 120px;
        border-radius: 999px;
        object-fit: cover;
        border: 2px solid var(--border);
        box-shadow: var(--shadow);
        margin-bottom: 24px;
      }

      .landing-name {
        font-size: clamp(2.5rem, 4vw, 4rem);
        margin: 0 0 12px;
        color: var(--accent);
      }

      .landing-title {
        font-size: 1.3rem;
        color: var(--fg-muted);
        margin: 0 0 32px;
      }

      .landing-nav {
        display: flex;
        justify-content: center;
        gap: 24px;
        margin-bottom: 48px;
        flex-wrap: wrap;
      }

      .landing-nav a {
        display: inline-flex;
        align-items: center;
        padding: 16px 32px;
        background: var(--bg-soft);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        color: var(--fg);
        text-decoration: none;
        font-size: 1.1rem;
        font-weight: 500;
        transition: all 0.15s ease;
        box-shadow: var(--shadow);
      }

      .landing-nav a:hover {
        background: var(--accent-soft);
        border-color: var(--accent);
        color: var(--accent);
        text-decoration: none;
      }

      @media (max-width: 768px) {
        .landing-nav {
          flex-direction: column;
          align-items: center;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <!-- Theme toggle button for landing page -->
      <div style="position: absolute; top: 24px; right: 24px;">
        <button class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle theme">
          <svg class="icon icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
          <svg class="icon icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
      </div>
      
      <div class="landing-hero">
        <img
          src="/HeadShot/IMG_0622 2.jpg"
          alt="Srinath Shrestha"
          class="landing-avatar"
        />
        <h1 class="landing-name">Srinath Shrestha</h1>
        <p class="landing-title">Full Stack Developer & Tech Enthusiast</p>
      </div>

      <div class="landing-nav">
        <a href="/blogs">My Blogs</a>
        <a href="/portfolio">Portfolio</a>
      </div>
    </main>
  </body>
</html>
