<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("../partials/head") %>
    <style>
      /* ── Analytics summary bar ── */
      .stats-bar {
        display: flex; gap: 1.5rem; flex-wrap: wrap;
        padding: 1rem 1.25rem; margin-bottom: 1.5rem;
        border: 1px solid var(--border, #e0e0e0); border-radius: 6px;
        background: var(--surface, transparent);
      }
      .stat-item { display: flex; flex-direction: column; gap: .2rem; }
      .stat-label { font-size: .7rem; text-transform: uppercase; letter-spacing: .06em; color: var(--muted, #888); }
      .stat-value { font-size: 1.4rem; font-weight: 700; line-height: 1; }

      .referrers { margin-top: 1rem; }
      .referrers h3 { font-size: .8rem; text-transform: uppercase; letter-spacing: .06em; color: var(--muted, #888); margin-bottom: .5rem; }
      .referrer-row { display: flex; justify-content: space-between; font-size: .82rem; padding: .2rem 0; border-bottom: 1px solid var(--border, #f0f0f0); }
      .referrer-row:last-child { border-bottom: none; }
      .referrer-source { font-family: monospace; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 260px; }

      /* ── View count pill on post rows ── */
      .view-pill {
        font-size: .7rem; padding: .15rem .45rem; border-radius: 20px;
        background: var(--hover-bg, #f0f0f0); color: var(--muted, #666);
        white-space: nowrap; flex-shrink: 0; line-height: 1.4;
      }
      .view-pill .week { color: var(--accent, #4a9eff); font-weight: 600; }
    </style>
  </head>
  <body class="writer-mode">
    <main>
      <header class="admin-header">
        <h1>Writer Console</h1>
        <nav>
          <a href="/admin/media">Media</a>
          <a href="/">Index</a>
          <a href="/rss.xml">RSS</a>
          <button class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle theme">
            <svg class="icon icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            <svg class="icon icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          </button>
          <form method="post" action="/admin/logout">
            <button class="button" type="submit">Logout</button>
          </form>
        </nav>
      </header>

      <section class="writer-shell admin-grid">
        <aside class="writer-sidebar">
          <div class="sidebar-actions">
            <a class="button" href="/admin/posts/new">New draft</a>
          </div>
          <div class="post-groups">
            <section class="post-group">
              <div class="group-header">
                <h2>Published</h2>
                <span class="count-pill"><%= published.length %></span>
              </div>
              <ul class="post-list">
                <% if (!published.length) { %>
                <li class="empty-row">No published posts yet.</li>
                <% } else { %> <% published.forEach(function(post) {
                  var vc = viewCounts[post.slug] || { total: 0, week: 0 };
                %>
                <li class="post-row">
                  <span class="post-link-static"
                    ><a href="/blogs/<%= post.slug %>" target="_blank"
                      ><%= post.title %></a
                    ></span
                  >
                  <span class="view-pill" title="<%= vc.total %> all-time · <%= vc.week %> this week">
                    <span class="week"><%= vc.week %>w</span>&nbsp;/ <%= vc.total %>
                  </span>
                  <a
                    class="button post-link"
                    href="/admin/posts/<%= post.slug %>/edit"
                    aria-label="Edit post"
                  >
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                  </a>
                  <form
                    method="post"
                    action="/admin/posts/<%= post.slug %>/delete"
                  >
                    <button class="button danger post-delete" type="submit" aria-label="Delete post">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                    </button>
                  </form>
                </li>
                <% }); %> <% } %>
              </ul>
            </section>

            <section class="post-group">
              <div class="group-header">
                <h2>Drafts</h2>
                <span class="count-pill"><%= drafts.length %></span>
              </div>
              <ul class="post-list">
                <% if (!drafts.length) { %>
                <li class="empty-row">No drafts on file.</li>
                <% } else { %> <% drafts.forEach(function(post) { %>
                <li class="post-row">
                  <span class="post-link-static"><%= post.title %></span>
                  <a
                    class="button post-link"
                    href="/admin/posts/<%= post.slug %>/edit"
                    aria-label="Edit post"
                  >
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                  </a>
                  <form
                    method="post"
                    action="/admin/posts/<%= post.slug %>/delete"
                  >
                    <button class="button danger post-delete" type="submit" aria-label="Delete post">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                    </button>
                  </form>
                </li>
                <% }); %> <% } %>
              </ul>
            </section>
          </div>
        </aside>

        <section class="admin-help">
          <!-- Traffic summary -->
          <div class="stats-bar">
            <div class="stat-item">
              <span class="stat-label">Today</span>
              <span class="stat-value"><%= summary.today %></span>
            </div>
            <div class="stat-item">
              <span class="stat-label">7 days</span>
              <span class="stat-value"><%= summary.week %></span>
            </div>
            <div class="stat-item">
              <span class="stat-label">30 days</span>
              <span class="stat-value"><%= summary.month %></span>
            </div>
            <div class="stat-item">
              <span class="stat-label">All time</span>
              <span class="stat-value"><%= summary.allTime %></span>
            </div>
          </div>

          <% if (summary.topReferrers.length) { %>
          <div class="referrers">
            <h3>Top referrers (30 days)</h3>
            <% summary.topReferrers.forEach(function(r) { %>
            <div class="referrer-row">
              <span class="referrer-source"><%= r.source %></span>
              <span><%= r.count %></span>
            </div>
            <% }); %>
          </div>
          <% } else { %>
          <p style="color:var(--muted,#888);font-size:.875rem;">No referrer data yet — views will appear here as readers arrive.</p>
          <% } %>
        </section>
      </section>
    </main>
  </body>
</html>
