<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title><%= title ? `${title}` : blogTitle %></title>

<!-- Apply saved theme immediately to prevent flash -->
<script>
  // Load theme from localStorage before page renders.
  // This prevents the flash of wrong theme on reload.
  (function() {
    var saved = localStorage.getItem('theme') || 'dark';
    if (saved === 'light') {
      document.documentElement.setAttribute('data-theme', 'light');
    }
  })();
</script>

<link rel="stylesheet" href="/styles.css" />

<!--
  Syntax highlighting (Highlight.js)
  We load BOTH dark and light stylesheets, then disable the wrong one.
  This avoids SRI integrity hash issues when swapping href dynamically.
-->
<link
  rel="stylesheet"
  id="hljs-dark"
  href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark-dimmed.min.css"
  crossorigin="anonymous"
  referrerpolicy="no-referrer"
/>
<link
  rel="stylesheet"
  id="hljs-light"
  href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github.min.css"
  crossorigin="anonymous"
  referrerpolicy="no-referrer"
  disabled
/>
<script
  defer
  src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"
  crossorigin="anonymous"
  referrerpolicy="no-referrer"
></script>

<!-- Theme switcher and syntax highlight initialization -->
<script>
  // ── Highlight.js init ──────────────────────────────────────
  document.addEventListener("DOMContentLoaded", function () {
    try { if (window.hljs) window.hljs.highlightAll(); } catch (e) {}

    // Make sure the correct hljs stylesheet is active on load
    syncHighlightTheme();
  });

  window.addEventListener("load", function () {
    try { if (window.hljs) window.hljs.highlightAll(); } catch (e) {}
  });

  // ── Theme toggle ───────────────────────────────────────────
  function toggleTheme() {
    var root  = document.documentElement;
    var cur   = root.getAttribute('data-theme') || 'dark';
    var next  = cur === 'dark' ? 'light' : 'dark';

    // Flip theme attribute
    if (next === 'light') root.setAttribute('data-theme', 'light');
    else                  root.removeAttribute('data-theme');

    // Persist choice
    localStorage.setItem('theme', next);

    // Swap highlight.js stylesheet
    syncHighlightTheme();
  }

  // ── Sync highlight.js stylesheet to current theme ──────────
  // We toggle the "disabled" attribute on the two preloaded
  // <link> tags instead of rewriting href (avoids SRI issues).
  function syncHighlightTheme() {
    var isLight   = document.documentElement.getAttribute('data-theme') === 'light';
    var darkLink  = document.getElementById('hljs-dark');
    var lightLink = document.getElementById('hljs-light');

    if (darkLink)  darkLink.disabled  = isLight;
    if (lightLink) lightLink.disabled = !isLight;
  }
</script>

<link
  rel="alternate"
  type="application/rss+xml"
  title="<%= blogTitle %> RSS"
  href="/rss.xml"
/>
